<?xml version="1.0"?>
<ruleset name="Enterprise Security Ruleset"
         xmlns="http://pmd.sourceforge.net/ruleset/2.0.0"
         xmlns:xsi="http://www.w3.org/2001/XMLSchema-instance"
         xsi:schemaLocation="http://pmd.sourceforge.net/ruleset/2.0.0
                             https://pmd.sourceforge.io/ruleset_2_0_0.xsd">

    <description>
        PMD ruleset for enterprise Java projects with security focus.
        Covers security vulnerabilities, common bugs, and best practices.
    </description>

    <!-- ==================== SECURITY ==================== -->
    <rule ref="category/java/security.xml"/>

    <!-- ==================== ERROR PRONE ==================== -->
    <rule ref="category/java/errorprone.xml">
        <!-- Too noisy for most projects -->
        <exclude name="BeanMembersShouldSerialize"/>
        <exclude name="DataflowAnomalyAnalysis"/>
        <exclude name="AvoidLiteralsInIfCondition"/>
        <exclude name="AvoidFieldNameMatchingMethodName"/>
    </rule>

    <!-- ==================== BEST PRACTICES ==================== -->
    <rule ref="category/java/bestpractices.xml">
        <exclude name="GuardLogStatement"/>
        <exclude name="JUnitTestContainsTooManyAsserts"/>
        <exclude name="JUnitAssertionsShouldIncludeMessage"/>
        <exclude name="AbstractClassWithoutAbstractMethod"/>
        <!-- PMD 7.0 false positives: flags Collection, Map as implementation types -->
        <exclude name="LooseCoupling"/>
    </rule>

    <!-- ==================== MULTITHREADING ==================== -->
    <rule ref="category/java/multithreading.xml">
        <exclude name="UseConcurrentHashMap"/>
        <!-- Not a J2EE webapp — threading is intentional, especially in HPC examples -->
        <exclude name="DoNotUseThreads"/>
    </rule>

    <!-- ==================== DESIGN ==================== -->
    <rule ref="category/java/design.xml">
        <exclude name="LawOfDemeter"/>
        <exclude name="LoosePackageCoupling"/>
        <exclude name="DataClass"/>
        <exclude name="TooManyMethods"/>
        <exclude name="ExcessiveImports"/>
        <exclude name="AvoidCatchingGenericException"/>
    </rule>
    <!-- Override CyclomaticComplexity threshold -->
    <rule ref="category/java/design.xml/CyclomaticComplexity">
        <properties>
            <property name="methodReportLevel" value="15"/>
            <property name="classReportLevel" value="80"/>
        </properties>
    </rule>
    <!-- Override CognitiveComplexity threshold -->
    <rule ref="category/java/design.xml/CognitiveComplexity">
        <properties>
            <property name="reportLevel" value="20"/>
        </properties>
    </rule>

    <!-- ==================== PERFORMANCE ==================== -->
    <rule ref="category/java/performance.xml"/>

    <!-- ==================== SUPPRESSIONS ==================== -->
    <!--
        Suppress PMD warnings in code:
          @SuppressWarnings("PMD.RuleName")
          // NOPMD - reason for suppression

        Exclude files via pattern:
    -->
    <exclude-pattern>.*/generated/.*</exclude-pattern>
    <exclude-pattern>.*/jmh_generated/.*</exclude-pattern>
    <exclude-pattern>.*/target/.*</exclude-pattern>

</ruleset>
