<?xml version="1.0" encoding="UTF-8"?>
<FindBugsFilter>
    <!--
        SpotBugs / Find Security Bugs exclusion filter.
        See: https://spotbugs.readthedocs.io/en/stable/filter.html
    -->

    <!-- Suppress low-confidence findings in generated code -->
    <Match>
        <Source name="~.*Generated.*\.java"/>
    </Match>

    <!-- Suppress serialization warnings on DTOs (common false positive) -->
    <Match>
        <Bug pattern="SE_BAD_FIELD"/>
        <Class name="~.*Dto"/>
    </Match>

    <!-- SPRING_ENDPOINT is informational, not a defect -->
    <Match>
        <Bug pattern="SPRING_ENDPOINT"/>
    </Match>

    <!-- CRLF_INJECTION_LOGS: false positive with SLF4J parameterized logging -->
    <Match>
        <Bug pattern="CRLF_INJECTION_LOGS"/>
        <Package name="~com\.example\.template\..*"/>
    </Match>

    <!-- Example code: suppress common false positives and style warnings -->
    <Match>
        <Or>
            <Bug pattern="EI_EXPOSE_REP"/>
            <Bug pattern="EI_EXPOSE_REP2"/>
            <Bug pattern="THROWS_METHOD_THROWS_RUNTIMEEXCEPTION"/>
            <Bug pattern="THROWS_METHOD_THROWS_CLAUSE_BASIC_EXCEPTION"/>
            <Bug pattern="NP_NULL_ON_SOME_PATH_FROM_RETURN_VALUE"/>
            <Bug pattern="RV_RETURN_VALUE_IGNORED_BAD_PRACTICE"/>
            <Bug pattern="DM_CONVERT_CASE"/>
            <Bug pattern="CNT_ROUGH_CONSTANT_VALUE"/>
            <Bug pattern="DLS_DEAD_LOCAL_STORE"/>
            <Bug pattern="IMPROPER_UNICODE"/>
            <Bug pattern="PREDICTABLE_RANDOM"/>
            <Bug pattern="SBSC_USE_STRINGBUFFER_CONCATENATION"/>
            <Bug pattern="URF_UNREAD_FIELD"/>
        </Or>
        <Package name="~com\.example\.template\..*"/>
    </Match>
</FindBugsFilter>
